# Frontend (Vite - must be prefixed with VITE_)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Supabase Edge Function Secrets (set via Supabase Dashboard > Edge Functions > Secrets)
# N8N_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/your-path
# N8N_WEBHOOK_SECRET=your-webhook-secret-here
# GEMINI_API_KEY=your-gemini-api-key-here

# Auto-provisioned by Supabase (do not set manually):
# SUPABASE_URL
# SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY
# SUPABASE_DB_URL
